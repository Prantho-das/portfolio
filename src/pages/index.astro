---

<Layout title="Prantho Das | Full Stack Developer & AI Expert">
  <!-- Navigation -->
  <nav class="nav">
    <div class="container">
      <div class="nav-inner">
        <a href="#" class="logo">
          <img src="/DSCF7857.JPG" alt="Prantho" class="logo-img" />
          <span class="logo-text">Prantho Das</span>
        </a>
        <div class="nav-links" id="navLinks">
          <a href="#about"><span class="en-text">About</span><span class="bn-text">সম্পর্কে</span></a>
          <a href="#services"><span class="en-text">Services</span><span class="bn-text">সেবাসমূহ</span></a>
          <a href="#expertise"><span class="en-text">Expertise</span><span class="bn-text">দক্ষতা</span></a>
          <div class="nav-actions">
            <div class="nav-lang">
              <button class="lang-btn active" data-lang="en">EN</button>
              <button class="lang-btn" data-lang="bn">বাং</button>
            </div>
            <a href="#contact" class="btn btn-nav btn-sm">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
              <span class="en-text">Let's Talk</span><span class="bn-text">কথা বলুন</span>
            </a>
          </div>
        </div>
        <button class="mobile-menu" aria-label="Menu" onclick="document.getElementById('navLinks').classList.toggle('active')">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
        </button>
      </div>
    </div>
  </nav>

  <script is:inline>
    (function() {
      const STORAGE_KEY = 'prantho_portfolio_lang';
      const langBtns = document.querySelectorAll('.nav-lang .lang-btn');
      
      function setLanguage(lang) {
        localStorage.setItem(STORAGE_KEY, lang);
        document.documentElement.setAttribute('data-lang', lang);
        langBtns.forEach(btn => {
          btn.classList.toggle('active', btn.dataset.lang === lang);
        });
      }
      
      langBtns.forEach(btn => {
        btn.addEventListener('click', () => setLanguage(btn.dataset.lang));
      });
      
      const savedLang = localStorage.getItem(STORAGE_KEY) || 'en';
      setLanguage(savedLang);
    })();
  </script>

  <!-- Hero Section -->
  <section class="hero">
    <div class="hero-bg">
      <div class="hero-blob blob-1"></div>
      <div class="hero-blob blob-2"></div>
      <div class="hero-grid-lines"></div>
    </div>
    <div class="container">
      <div class="hero-grid">
        <div class="hero-content">
          <div class="hero-badge">
            <span class="pulse-dot"></span>
            <span class="en-text">Available for new projects</span><span class="bn-text">নতুন প্রজেক্টের জন্য উপলব্ধ</span>
          </div>
          <h1 class="hero-title">
            <span class="line en-text">Crafting</span><span class="line bn-text">কোডের মাধ্যমে</span>
            <span class="gradient-text en-text">Digital Excellence</span><span class="gradient-text bn-text">ডিজিটাল</span>
            <span class="line en-text">Through Code</span><span class="line bn-text">শ্রেষ্ঠত্ব</span>
          </h1>
          <p class="hero-subtitle en-text">Full-stack developer specializing in enterprise Laravel applications, modern Astro sites, and AI-powered automation solutions.</p>
          <p class="hero-subtitle bn-text">এন্টারপ্রাইজ Laravel অ্যাপ্লিকেশন, আধুনিক Astro সাইট এবং AI-চালিত অটোমেশন সমাধানে বিশেষায়িত ফুল-স্ট্যাক ডেভেলপার।</p>
          <div class="hero-buttons">
            <a href="#contact" class="btn btn-primary btn-lg">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
              <span class="en-text">Start a Project</span><span class="bn-text">প্রজেক্ট শুরু করুন</span>
            </a>
            <a href="#services" class="btn btn-outline btn-lg">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="16"/><line x1="8" y1="12" x2="16" y2="12"/></svg>
              <span class="en-text">View Pricing</span><span class="bn-text">মূল্য দেখুন</span>
            </a>
          </div>
          <div class="hero-stats">
            <div class="stat">
              <div class="stat-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              </div>
              <span class="stat-number">5+</span>
              <span class="stat-label en-text">Years</span><span class="stat-label bn-text">বছর</span>
            </div>
            <div class="stat">
              <div class="stat-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>
              </div>
              <span class="stat-number">50+</span>
              <span class="stat-label en-text">Projects</span><span class="stat-label bn-text">প্রজেক্ট</span>
            </div>
            <div class="stat">
              <div class="stat-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
              </div>
              <span class="stat-number">30+</span>
              <span class="stat-label en-text">Clients</span><span class="stat-label bn-text">ক্লায়েন্ট</span>
            </div>
          </div>
        </div>
        <div class="hero-image">
          <div class="image-container">
            <img src="/DSCF7857.JPG" alt="Prantho Das" />
            <div class="image-ring"></div>
            <div class="floating-badge badge-1">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m18 16 4-4-4-4"/><path d="m6 8-4 4 4 4"/><path d="m14.5 4-5 16"/></svg>
              Laravel Expert
            </div>
            <div class="floating-badge badge-2">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2v4"/><path d="m6.8 15-3.5 2"/><path d="m20.7 17-3.5-2"/><path d="M6.8 9 3.3 7"/><path d="m20.7 7-3.5 2"/><path d="m9 22 3-8 3 8"/><path d="M8 22h8"/><path d="M12 2a4 4 0 0 0-4 4c0 1.5.8 2.8 2 3.4"/></svg>
              AI Automation
            </div>
          </div>
        </div>
      </div>
    </div>
    <div class="scroll-indicator">
      <div class="mouse">
        <div class="wheel"></div>
      </div>
    </div>
  </section>

  <!-- About Section -->
  <section id="about" class="section">
    <div class="container">
      <div class="about-grid">
        <div class="about-image">
          <img src="/DSCF7856.JPG" alt="Working" />
          <div class="about-badge">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2v4"/><path d="m6.8 15-3.5 2"/><path d="m20.7 17-3.5-2"/><path d="M6.8 9 3.3 7"/><path d="m20.7 7-3.5 2"/><path d="m9 22 3-8 3 8"/><path d="M8 22h8"/><path d="M12 2a4 4 0 0 0-4 4c0 1.5.8 2.8 2 3.4"/></svg>
            AI Powered
          </div>
        </div>
        <div class="about-content">
          <span class="badge">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            <span class="en-text">About Me</span><span class="bn-text">আমার সম্পর্কে</span>
          </span>
          <h2>
            <span class="en-text">Building </span><span class="bn-text">ফলাফল </span>
            <span class="gradient-text en-text">Digital Solutions</span><span class="gradient-text bn-text">ডিজিটাল সমাধান</span><br/>
            <span class="en-text">That Drive Results</span><span class="bn-text">নির্মাণ করা হচ্ছে</span>
