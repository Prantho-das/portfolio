    contact: { badge: 'যোগাযোগ', title: 'একসাথে', titleHighlight: 'তৈরি করি', subtitle: 'আপনার ডিজিটাল উপস্থিতি রূপান্তরিত করতে প্রস্তুত? একটি বিনামূল্যে ১৫ মিনিটের কৌশল কল বুক করুন।', phone: { label: 'ফোন / WhatsApp', value: '+৮৮০ ১৭৯৪ ১৮৮ ৮৩৫' }, linkedin: { label: 'LinkedIn', value: 'linkedin.com/in/pranthodas' }, github: { label: 'GitHub', value: 'github.com/Prantho-das' }, card: { name: 'প্রন্থ দাস', role: 'ফুল স্ট্যাক ডেভেলপার', whatsapp: 'WhatsApp এ চ্যাট করুন', free: '১৫ মিনিট বিনামূল্যে পরামর্শ' } },
